fn image_format(path: string) -> string {
    if path.ends_with(".png") { return "png" }
    if path.ends_with(".jpg") || path.ends_with(".jpeg") { return "jpg" }
    if path.ends_with(".bmp") { return "bmp" }
    if path.ends_with(".gif") { return "gif" }
    return "unknown"
}

fn image_buffer_size(width: int, height: int, channels: int) -> int {
    return width * height * channels
}

fn image_is_supported(path: string) -> bool {
    var fmt = image_format(path)
    return fmt != "unknown"
}

fn main() -> int {
    assert_eq(image_format("photo.png"), "png")
    assert_eq(image_format("photo.jpg"), "jpg")
    assert_eq(image_format("photo.bmp"), "bmp")
    assert_eq(image_format("photo.txt"), "unknown")
    assert_eq(image_buffer_size(800, 600, 4), 1920000)
    assert_eq(image_buffer_size(1, 1, 3), 3)
    if image_is_supported("test.png") { println("supported: pass") }
    if !image_is_supported("test.txt") { println("unsupported: pass") }
    
    println("image: 8 tests passed")
    return 0
}
