test "detect png" {
    // Image format detection by extension
    var png = "photo.png"
    var jpg = "photo.jpg"
    assert(png.ends_with(".png"))
}

test "detect jpg" {
    // Image format detection by extension
    var png = "photo.png"
    var jpg = "photo.jpg"
    assert(jpg.ends_with(".jpg"))
}

test "pixel buffer size" {
    // Image format detection by extension
    var png = "photo.png"
    var jpg = "photo.jpg"
    // Pixel math
    var w = 800
    var h = 600
    var channels = 4  // RGBA
    var size = w * h * channels
    assert_eq(size, 1920000)
}
